# Conexão Supabase / Lovable Cloud
# No Lovable, estas variáveis são INJETADAS automaticamente no build.
# Este arquivo serve apenas para DESENVOLVIMENTO LOCAL (vite dev).
# Copie para `.env` e preencha com os valores do seu projeto.
# A publishable/anon key é pública por design (protegida por RLS) — não é segredo.

VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="seu-project-id"

# Aliases usados por algumas ferramentas
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sua-anon-publishable-key"
